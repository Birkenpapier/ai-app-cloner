{
  "name": "ExampleNotes",
  "source": { "mode": "screenshots", "ref": "docs/screenshots/" },
  "tokens": {
    "colors": {
      "background": "#ffffff",
      "foreground": "#0a0a0a",
      "primary": "#208aef",
      "primary-foreground": "#ffffff",
      "muted": "#f4f4f5",
      "muted-foreground": "#71717a",
      "border": "#e4e4e7",
      "dark-background": "#0a0a0a",
      "dark-foreground": "#fafafa"
    },
    "fonts": { "sans": "Inter", "mono": "Menlo" },
    "spacing": { "screenX": 16, "gap": 12 },
    "radii": { "card": 16, "button": 10 }
  },
  "navigation": {
    "type": "tabs",
    "items": ["Home", "Search", "Profile"]
  },
  "screens": [
    {
      "name": "Home",
      "route": "/",
      "states": ["default", "empty", "loading", "dark"],
      "sourceShots": ["home-filled.png", "home-empty.png", "home-loading.png", "home-dark.png"],
      "transitionsTo": ["NoteDetail"],
      "spec": "docs/research/components/home.spec.md"
    },
    {
      "name": "Search",
      "route": "/search",
      "states": ["default", "results"],
      "sourceShots": ["search-empty.png", "search-results.png"],
      "transitionsTo": ["NoteDetail"],
      "spec": "docs/research/components/search.spec.md"
    },
    {
      "name": "Profile",
      "route": "/profile",
      "states": ["default", "dark"],
      "sourceShots": ["profile.png", "profile-dark.png"],
      "transitionsTo": ["Settings"],
      "spec": "docs/research/components/profile.spec.md"
    },
    {
      "name": "NoteDetail",
      "route": "/note/[id]",
      "states": ["default"],
      "sourceShots": ["note-detail.png"],
      "transitionsTo": [],
      "spec": "docs/research/components/note-detail.spec.md"
    },
    {
      "name": "Settings",
      "route": "/settings",
      "states": ["default"],
      "sourceShots": ["settings.png"],
      "transitionsTo": [],
      "spec": "docs/research/components/settings.spec.md"
    }
  ],
  "dataModel": {
    "generatedBy": "two-pass-inference",
    "confidence": "proposal",
    "notes": "Inferred from the Notes UI. Every field type and the folderId relation are proposals to review, not facts. No business logic, auth, or hidden tables are recoverable from screenshots.",
    "entities": [
      {
        "name": "Folder",
        "table": "folders",
        "sourceScreens": ["Home"],
        "confidence": "medium",
        "fields": [
          { "name": "id", "type": "id" },
          { "name": "name", "type": "text", "evidence": "folder chips in the Home header" },
          { "name": "createdAt", "type": "timestamp", "optional": true }
        ],
        "sampleRows": [
          { "id": "f1", "name": "Personal", "createdAt": 1720000000000 },
          { "id": "f2", "name": "Work", "createdAt": 1720000100000 }
        ]
      },
      {
        "name": "Note",
        "table": "notes",
        "sourceScreens": ["Home", "NoteDetail"],
        "confidence": "high",
        "fields": [
          { "name": "id", "type": "id" },
          { "name": "title", "type": "text", "evidence": "note card title" },
          { "name": "body", "type": "text", "optional": true, "evidence": "note detail body" },
          { "name": "pinned", "type": "boolean", "evidence": "pin icon on cards" },
          { "name": "color", "type": "enum", "enumValues": ["default", "yellow", "green"], "evidence": "card background swatches" },
          { "name": "createdAt", "type": "timestamp", "optional": true }
        ],
        "relations": [
          { "field": "folderId", "references": "folders", "kind": "belongsTo", "confidence": "hint", "evidence": "Home list filtered by folder chips" }
        ],
        "sampleRows": [
          { "id": "n1", "title": "Welcome", "body": "Your first note.", "pinned": true, "color": "yellow", "folderId": "f1", "createdAt": 1720000200000 },
          { "id": "n2", "title": "Groceries", "body": "Milk, eggs, bread.", "pinned": false, "color": "green", "folderId": "f1", "createdAt": 1720000300000 },
          { "id": "n3", "title": "Standup notes", "body": null, "pinned": false, "color": "default", "folderId": "f2", "createdAt": 1720000400000 }
        ]
      }
    ]
  }
}
